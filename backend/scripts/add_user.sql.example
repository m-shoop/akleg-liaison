-- Template for adding a single user with one role assignment.
-- Copy this file to add_user.sql, fill in the values at the top, and run once.
--
--     cp add_user.sql.example add_user.sql
--     # edit the four values in the INSERT below
--     psql "$DATABASE_URL" -v ON_ERROR_STOP=1 -f add_user.sql
--
-- The real file is gitignored so emails never enter version control.
--
-- Idempotent: re-running with a corrected name/status updates the existing row.
-- Re-running with the same role_name is a no-op for user_roles.
-- Wrapped in a transaction so a typo or constraint violation rolls back cleanly.

BEGIN;

-- 1. The user being added — single source of truth for the rest of the script.
--    Edit this row and nothing else.

CREATE TEMP TABLE _new_user (
    email       text PRIMARY KEY,
    name        text,
    user_status user_status_enum NOT NULL,
    role_name   text NOT NULL
) ON COMMIT DROP;

INSERT INTO _new_user (email, name, user_status, role_name) VALUES
    ('newuser@example.com', 'First Last', 'inactive', 'viewer');
    -- user_status: 'inactive' (must register to set password) | 'active' | 'deleted'
    -- role_name:   'viewer' | 'admin'

-- 2. UPSERT the user row. Status 'inactive' leaves hashed_password NULL so the
--    user goes through the normal registration / activation flow on first login.
INSERT INTO users (email, name, user_status)
SELECT email, name, user_status FROM _new_user
ON CONFLICT (email) DO UPDATE
SET name        = EXCLUDED.name,
    user_status = EXCLUDED.user_status;

-- 3. Assign the role. ON CONFLICT DO NOTHING so re-running doesn't fail on the
--    composite primary key.
INSERT INTO user_roles (user_id, role_id)
SELECT u.id, r.id
FROM users u
JOIN _new_user n ON n.email = u.email
JOIN roles    r ON r.name  = n.role_name
ON CONFLICT (user_id, role_id) DO NOTHING;

-- 4. Sanity check. RAISE NOTICE only — review the output before COMMIT lands.
DO $$
DECLARE
    msg text;
BEGIN
    SELECT format(
        'user=%s status=%s name=%s roles=[%s]',
        u.email,
        u.user_status,
        COALESCE(u.name, '(null)'),
        COALESCE(string_agg(r.name, ',' ORDER BY r.name), '(none)')
    ) INTO msg
    FROM users u
    LEFT JOIN user_roles ur ON ur.user_id = u.id
    LEFT JOIN roles      r  ON r.id       = ur.role_id
    WHERE u.email IN (SELECT email FROM _new_user)
    GROUP BY u.id, u.email, u.user_status, u.name;

    RAISE NOTICE '%', msg;
END$$;

COMMIT;
