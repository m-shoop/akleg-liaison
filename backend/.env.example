DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:PORT/DATABASE
MISTRAL_API_KEY=your-mistral-api-key-here
SECRET_KEY=your-secret-key-here

# Resend transactional email
RESEND_API_KEY=your-resend-api-key-here
EMAIL_FROM_ADDRESS=Your App <noreply@mail.example.com>
EMAIL_REPLY_TO_ADDRESS=contact@example.com

# Full base URL used to construct activation links in emails
# Dev:  http://localhost:5173
# Prod: https://www.example.com
FRONTEND_BASE_URL=https://www.example.com

# Set to false in local dev (HTTP); must be true in production (HTTPS)
COOKIE_SECURE=true
